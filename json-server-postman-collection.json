{
  "info": {
    "name": "JSON Server CI Stable - Corrected",
    "_postman_id": "ci-stable-v3",
    "description": "Collection corrigida com validação real de API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],

  "item": [

    {
      "name": "00 - HEALTH CHECK (MUST PASS)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API is reachable', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "01 - GET Users (Smoke)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Users endpoint must exist', () => {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "pm.test('Response is array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "02 - CREATE User (STRICT CI)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CI User {{timestamp}}\"\n}"
        },
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set('timestamp', Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CREATE user must succeed', () => {",
              "    pm.expect(pm.response.code).to.eql(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('User has ID', () => {",
              "    pm.expect(json.id).to.exist;",
              "});",
              "",
              "pm.collectionVariables.set('user_id', json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "03 - GET User By ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User must exist', () => {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "04 - UPDATE User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated User\"\n}"
        },
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update must succeed', () => {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "05 - DELETE User",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete must succeed', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}