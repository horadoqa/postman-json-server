{
  "info": {
    "name": "JSON Server CI Stable Tests",
    "_postman_id": "9a2c2f11-qa-ci-stable",
    "description": "Collection estável para CI com JSON Server",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - GET All Users (Smoke)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is array', () => {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "02 - CREATE User (CI Safe)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CI User {{timestamp}}\"\n}"
        },
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set('timestamp', Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Created successfully', () => {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json.id).to.exist;",
              "",
              "// collection variable (CI safe)",
              "pm.collectionVariables.set('user_id', json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "03 - GET User By ID (Independent Check)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is valid', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});",
              "",
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    pm.expect(json.id).to.exist;",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "04 - UPDATE User (CI Safe)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated CI User\"\n}"
        },
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update allowed', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "05 - DELETE User (CI Safe)",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete response valid', () => {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204, 404]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}