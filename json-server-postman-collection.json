{
  "info": {
    "name": "JSON Server CI Stable - Precheck Version",
    "_postman_id": "ci-precheck-v1",
    "description": "Collection com validação de API antes dos testes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],

  "item": [

    {
      "name": "00 - API HEALTH CHECK (CRITICAL)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API must be reachable', function () {",
              "    pm.expect(pm.response.code).to.eql(200);",
              "});",
              "",
              "pm.test('Must return array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "01 - CREATE User (SAFE CI)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"CI User {{timestamp}}\"\n}"
        },
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set('timestamp', Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CREATE must return 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.expect(json.id).to.exist;",
              "",
              "pm.collectionVariables.set('user_id', json.id);"
            ]
          }
        }
      ]
    },

    {
      "name": "02 - GET User By ID (PRECHECKED)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User must exist', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "03 - UPDATE User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated CI User\"\n}"
        },
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update must succeed', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "04 - DELETE User",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete must succeed', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}