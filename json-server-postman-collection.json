{
  "info": {
    "name": "JSON Server API Tests",
    "_postman_id": "c1a9b9c2-1234-4f56-8abc-123456789000",
    "description": "Collection para testar JSON Server localmente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "user_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "GET All Users",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Teste User\"\n}"
        },
        "url": "{{base_url}}/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.environment.set('user_id', jsonData.id);",
              "",
              "pm.test('User created has ID', function () {",
              "    pm.expect(jsonData).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET User By ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('User has correct ID', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get('user_id')));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PUT Update User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Updated User\"\n}"
        },
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('User updated', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql('Updated User');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE User",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/users/{{user_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 or 204', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}